# Copy to server/.env and client/.env as needed

# Server
PORT=5000
MONGODB_URI=mongodb://localhost:27017/ai-video-interview
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Storage (Phase 1: local disk; later: s3 | minio)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
